# Configurações do Banco de Dados Azure (PostgreSQL)
# Preencha nas configurações do Projeto (Settings > Environment Variables)
DB_HOST=seu_servidor.postgres.database.azure.com
DB_USER=seu_usuario@seu_servidor  # IMPORTANTE: Azure pode exigir o sufixo @servidor
DB_PASS=sua_senha
DB_NAME=postgres
DB_PORT=5432
DB_SSL=true

# Outras Configurações
GEMINI_API_KEY=sua_chave_aqui
NODE_ENV=production
